# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.pytest_cache/

# Packaging (export_engine.py / pip / build)
dist/
build/
*.egg-info/

# Databases (Local saves and universes)
# Personal universes stay untracked, but the bundled default universe
# (Universe-as-Code source) is versioned — only its compiled cache is not.
universes/*
!universes/Myria/
universes/Myria/.axiom-cache/
vector/
auto_backups/
/saves/

# Illustrations générées en jeu (assets/<uuid-de-save>/…) — les .png à plat
# à la racine d'assets/ (captures du README) restent versionnés.
/assets/*/

# Debug/Temp files at root (should be kept clean)
debug_*.db*
*.db-shm
*.db-wal

# IDEs
.vscode/
.idea/
.directory

.claude/
mise.toml

# Documentation (Sphinx) — build output + compiled gettext catalogs
docs/_build/
*.mo
