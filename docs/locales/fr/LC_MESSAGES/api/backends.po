msgid "Conversation turns (system, user, assistant)."
msgstr "Tours de conversation (system, user, assistant)."

#: axiom.backends.gemini.GeminiClient.complete:8 of
msgid "Ignored; use stream_tokens() for token streaming."
msgstr "Ignoré ; utiliser stream_tokens() pour le streaming de tokens."

#: axiom.backends.gemini.GeminiClient.complete:11
#: axiom.backends.gemini.GeminiClient.stream_tokens:6 of
msgid "Currently unused for Gemini."
msgstr "Actuellement inutilisé pour Gemini."

