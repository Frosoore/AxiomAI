#: ../../api/runtime.md:23
msgid "`axiom.time_system`"
msgstr ""

#: axiom.time_system:1 of
msgid "core/time_system.py"
msgstr ""

#: axiom.time_system:3 of
msgid ""
"Flexible time and calendar system for Axiom AI. Allows custom minutes per"
" hour, hours per day, and named months."
msgstr ""
"Système de temps et de calendrier flexible pour Axiom AI. Autorise des "
"minutes par heure, heures par jour et noms de mois personnalisés."

#: axiom.time_system.TimeComponents:1 of
msgid "Decomposition of an instant into raw data (zero presentation/translation)."
msgstr ""
"Décomposition d'un instant en données brutes (zéro "
"présentation/traduction)."

#: axiom.time_system.TimeComponents:3 of
msgid ""
"`phase_key` is a stable key among dawn/morning/afternoon/dusk/night; "
"`month_name` comes from the universe calendar (data, not a translation)."
msgstr ""
"`phase_key` est une clé stable parmi dawn/morning/afternoon/dusk/night ; "
"`month_name` provient du calendrier de l'univers (une donnée, pas une "
"traduction)."

#: axiom.time_system.TimeComponents.year:1 of
msgid "Alias for field number 0"
msgstr "Alias du champ numéro 0"

#: axiom.time_system.TimeComponents.month_name:1 of
msgid "Alias for field number 1"
msgstr "Alias du champ numéro 1"

#: axiom.time_system.TimeComponents.day:1 of
msgid "Alias for field number 2"
msgstr "Alias du champ numéro 2"

#: axiom.time_system.TimeComponents.hour:1 of
msgid "Alias for field number 3"
msgstr "Alias du champ numéro 3"

#: axiom.time_system.TimeComponents.minute:1 of
msgid "Alias for field number 4"
msgstr "Alias du champ numéro 4"

#: axiom.time_system.TimeComponents.phase_key:1 of
msgid "Alias for field number 5"
msgstr "Alias du champ numéro 5"

#: axiom.time_system.CalendarConfig:1 of
msgid "Configuration for a custom calendar."
msgstr "Configuration d'un calendrier personnalisé."

#: axiom.time_system.TimeSystem:1 of
msgid "Handles time conversion and formatting based on a CalendarConfig."
msgstr "Gère la conversion et le formatage du temps selon une CalendarConfig."

#: axiom.time_system.TimeSystem.get_time_components:1 of
msgid "Decompose cumulative minutes into (year, month, day, h, min, phase key)."
msgstr ""
"Décompose des minutes cumulées en (année, mois, jour, h, min, clé de "
"phase)."

#: axiom.time_system.TimeSystem.get_time_components:3 of
msgid ""
"Raw data only: no translation. The frontend localises the display from "
"these fields."
msgstr ""
"Données brutes uniquement : aucune traduction. Le frontend localise "
"l'affichage à partir de ces champs."

#: axiom.time_system.TimeSystem.get_time_string:1 of
msgid ""
"Default English rendering (dev / CLI / library). Zero engine-side "
"localisation."
msgstr ""
"Rendu anglais par défaut (dev / CLI / librairie). Zéro localisation côté "
"moteur."

#: axiom.time_system.TimeSystem.get_time_string:3 of
msgid ""
"The GUI does NOT go through here: it formats through its own localisation"
" layer to display in the user's language."
msgstr ""
"Le GUI ne passe PAS par ici : il formate via sa propre couche de "
"localisation pour afficher dans la langue de l'utilisateur."

#: axiom.time_system.TimeSystem.components_to_minutes:1 of
msgid ""
"Convert a simplified (Day, Hour, Min) UI input back to cumulative session"
" minutes."
msgstr ""
"Convertit une saisie UI simplifiée (Jour, Heure, Min) en minutes de "
"session cumulées."

#: axiom.time_system.TimeSystem.minutes_to_components:1 of
msgid "Convert session minutes back to Day, Hour, Min."
msgstr "Convertit des minutes de session en Jour, Heure, Min."

#: ../../api/runtime.md:30
msgid "`axiom.rules`"
msgstr ""

#: axiom.rules:1 of
msgid "core/rules_engine.py"
msgstr ""

#: axiom.rules:3 of
msgid "JSON-based Rules Engine for Axiom AI."
msgstr "Moteur de règles JSON d'Axiom AI."

#: axiom.rules:5 of
msgid ""
"The engine evaluates a set of creator-defined rules against an entity's "
"current stats and returns the list of actions that should be applied."
msgstr ""
"Le moteur évalue un ensemble de règles définies par le créateur contre "
"les stats courantes d'une entité et retourne la liste des actions à "
"appliquer."

#: axiom.rules:8 of
msgid "Canonical Rule JSON schema::"
msgstr "Schéma JSON canonique d'une règle ::"

#: axiom.rules:41 of
msgid "Notes"
msgstr "Notes"

#: axiom.rules:42 of
msgid "Rules are evaluated in ascending priority order (0 = highest priority)."
msgstr "Les règles sont évaluées par priorité croissante (0 = priorité maximale)."

#: axiom.rules:43 of
msgid "A rule with target_entity == '*' is evaluated for every entity."
msgstr "Une règle avec target_entity == '*' est évaluée pour chaque entité."

#: axiom.rules:44 of
msgid ""
"A rule with a specific target_entity is only evaluated when entity_id "
"matches."
msgstr ""
"Une règle avec un target_entity précis n'est évaluée que si entity_id "
"correspond."

#: axiom.rules:45 of
msgid ""
"apply_actions() is a pure function: it does NOT write to the database. "
"The caller (Arbitrator, Phase 2) is responsible for persisting changes "
"via EventSourcer."
msgstr ""
"apply_actions() est une fonction pure : elle n'écrit PAS dans la base. "
"L'appelant (l'Arbitrator) est responsable de persister les changements "
"via l'EventSourcer."

#: axiom.rules.RulesEngine:1 of
msgid "Evaluates JSON rules against entity stats and produces triggered actions."
msgstr ""
"Évalue les règles JSON contre les stats d'entités et produit les actions "
"déclenchées."

#: axiom.rules.RulesEngine:3 of
msgid ""
"List of rule dicts loaded from the Rules table of a universe db. Rules "
"are sorted by priority at construction time."
msgstr ""
"Liste de dicts de règles chargés depuis la table Rules d'une base "
"d'univers. Les règles sont triées par priorité à la construction."

#: axiom.rules.RulesEngine.evaluate:1 of
msgid "Evaluate all rules against an entity's current stats."
msgstr "Évalue toutes les règles contre les stats courantes d'une entité."

#: axiom.rules.RulesEngine.evaluate:3 of
msgid "Rules are processed in priority order.  A rule fires when:"
msgstr ""
"Les règles sont traitées par ordre de priorité.  Une règle se déclenche "
"quand :"

#: axiom.rules.RulesEngine.evaluate:4 of
msgid "Its target_entity is '*' OR equals entity_id, AND"
msgstr "Son target_entity est '*' OU égale entity_id, ET"

#: axiom.rules.RulesEngine.evaluate:5 of
msgid "Its conditions evaluate to True."
msgstr "Ses conditions s'évaluent à True."

#: axiom.rules.RulesEngine.evaluate:7 of
msgid "The ID of the entity whose stats are being tested."
msgstr "L'ID de l'entité dont les stats sont testées."

#: axiom.rules.RulesEngine.evaluate:8 of
msgid "The entity's current stat snapshot (stat_key -> value)."
msgstr "L'instantané de stats courant de l'entité (stat_key -> valeur)."

#: axiom.rules.RulesEngine.evaluate:10 of
msgid ""
"List of action dicts from all triggered rules, in priority order. May be "
"empty if no rules fire."
msgstr ""
"Liste des dicts d'actions de toutes les règles déclenchées, par ordre de "
"priorité. Peut être vide si aucune règle ne se déclenche."

#: axiom.rules.RulesEngine.apply_actions:1 of
msgid "Apply a list of actions to a stats snapshot and return the updated copy."
msgstr ""
"Applique une liste d'actions à un instantané de stats et retourne la "
"copie mise à jour."

#: axiom.rules.RulesEngine.apply_actions:3 of
msgid "This is a pure function.  The original stats dict is not mutated."
msgstr "C'est une fonction pure.  Le dict de stats d'origine n'est pas muté."

#: axiom.rules.RulesEngine.apply_actions:5 of
msgid "Supported action types:"
msgstr "Types d'actions pris en charge :"

#: axiom.rules.RulesEngine.apply_actions:7 of
msgid "stat_change — adds 'delta' (float) to an existing or zero-valued stat."
msgstr "stat_change — ajoute 'delta' (float) à une stat existante ou valant zéro."

#: axiom.rules.RulesEngine.apply_actions:8 of
msgid "stat_set — unconditionally sets a stat to the string form of 'value'."
msgstr ""
"stat_set — fixe inconditionnellement une stat à la forme chaîne de "
"'value'."

#: axiom.rules.RulesEngine.apply_actions:9 of
msgid "set_status — alias for stat_set; sets 'stat' to string 'value'."
msgstr "set_status — alias de stat_set ; fixe 'stat' à la chaîne 'value'."

#: axiom.rules.RulesEngine.apply_actions:10 of
msgid ""
"trigger_event — no immediate stat mutation; included in output for the "
"caller to dispatch as a new Event_Log entry."
msgstr ""
"trigger_event — aucune mutation de stat immédiate ; inclus dans la sortie"
" pour que l'appelant l'émette comme nouvelle entrée Event_Log."

#: axiom.rules.RulesEngine.apply_actions:13 of
msgid "List of action dicts (typically from evaluate())."
msgstr "Liste de dicts d'actions (typiquement issus d'evaluate())."

#: axiom.rules.RulesEngine.apply_actions:14 of
msgid "The current stat snapshot to transform."
msgstr "L'instantané de stats courant à transformer."

#: axiom.rules.RulesEngine.apply_actions:16 of
msgid "New Stats dict with all applicable mutations applied."
msgstr "Nouveau dict de stats avec toutes les mutations applicables appliquées."

#: ../../api/runtime.md:37
msgid "`axiom.modifiers`"
msgstr ""

#: axiom.modifiers:1 of
msgid "database/modifier_processor.py"
msgstr ""

#: axiom.modifiers:3 of
msgid "Active Modifiers management for Axiom AI."
msgstr "Gestion des modificateurs actifs d'Axiom AI."

#: axiom.modifiers:5 of
msgid ""
"Modifiers are temporary stat adjustments (buffs, debuffs, curses, "
"blessings) that automatically expire after a set amount of in-game time "
"(minutes). This module provides:"
msgstr ""
"Les modificateurs sont des ajustements de stats temporaires (buffs, "
"debuffs, malédictions, bénédictions) qui expirent automatiquement après "
"un temps in-game donné (minutes). Ce module fournit :"

#: axiom.modifiers:9 of
msgid ""
"apply_modifiers: overlay active modifiers on top of a base stat snapshot "
"for real-time display (read-only, no DB mutation)."
msgstr ""
"apply_modifiers : superpose les modificateurs actifs sur un instantané de"
" stats de base pour l'affichage temps réel (lecture seule, aucune "
"mutation de base)."

#: axiom.modifiers:11 of
msgid ""
"tick_modifiers: decrement all modifier durations by elapsed minutes and "
"purge expired ones from the database."
msgstr ""
"tick_modifiers : décrémente toutes les durées de modificateurs des "
"minutes écoulées et purge les expirés de la base."

#: axiom.modifiers:13 of
msgid "add_modifier: insert a new modifier row and return its ID."
msgstr ""
"add_modifier : insère une nouvelle ligne de modificateur et retourne son "
"ID."

#: axiom.modifiers:14 of
msgid ""
"snapshot_modifiers / rollback_modifiers: per-turn capture and rewind "
"restore of the table (it decays in minutes and isn't event-sourced — "
"TICKET-074)."
msgstr ""

#: axiom.modifiers:17 of
msgid ""
"Modifiers live in the Active_Modifiers table, which is keyed on "
"(modifier_id, entity_id, stat_key).  Every modifier carries a signed "
"float delta and a minutes_remaining countdown.  When minutes_remaining "
"reaches 0 the modifier is considered expired and will be deleted on the "
"next tick."
msgstr ""
"Les modificateurs vivent dans la table Active_Modifiers, indexée sur "
"(modifier_id, entity_id, stat_key).  Chaque modificateur porte un delta "
"float signé et un compte à rebours minutes_remaining.  Quand "
"minutes_remaining atteint 0, le modificateur est considéré expiré et sera"
" supprimé au tick suivant."

#: axiom.modifiers.ModifierProcessor:1 of
msgid "Manages temporary stat modifiers for entities in a universe database."
msgstr ""
"Gère les modificateurs de stats temporaires des entités d'une base "
"d'univers."

#: axiom.modifiers.ModifierProcessor:3 of
msgid ""
"Filesystem path to an existing universe .db file created by "
"database.schema.create_universe_db()."
msgstr ""
"Chemin de fichier d'un `.db` univers existant créé par "
"database.schema.create_universe_db()."

#: axiom.modifiers.ModifierProcessor.apply_modifiers:1 of
msgid "Overlay active modifiers on a base stat snapshot."
msgstr "Superpose les modificateurs actifs sur un instantané de stats de base."

#: axiom.modifiers.ModifierProcessor.apply_modifiers:3 of
msgid ""
"Reads all active modifiers for the entity and adds their deltas to the "
"corresponding numeric stats.  Non-numeric stats are left unchanged. This "
"method is read-only: it does not write to the database."
msgstr ""
"Lit tous les modificateurs actifs de l'entité et ajoute leurs deltas aux "
"stats numériques correspondantes.  Les stats non numériques sont laissées"
" inchangées. Cette méthode est en lecture seule : elle n'écrit pas dans "
"la base."

#: axiom.modifiers.ModifierProcessor.apply_modifiers:7 of
msgid ""
"The active save (used to scope modifier lookup via entity_id — modifiers "
"are stored per entity, not per save, but the entity must belong to this "
"save's universe)."
msgstr ""
"La save active (sert à délimiter la recherche de modificateurs via "
"entity_id — les modificateurs sont stockés par entité, pas par save, mais"
" l'entité doit appartenir à l'univers de cette save)."

#: axiom.modifiers.ModifierProcessor.apply_modifiers:10 of
msgid "The entity whose modifiers are applied."
msgstr "L'entité dont les modificateurs sont appliqués."

#: axiom.modifiers.ModifierProcessor.apply_modifiers:11 of
msgid ""
"The entity's current base stat snapshot from State_Cache (stat_key -> "
"string value)."
msgstr ""
"L'instantané de stats de base courant de l'entité depuis le State_Cache "
"(stat_key -> valeur chaîne)."

#: axiom.modifiers.ModifierProcessor.apply_modifiers:14 of
msgid ""
"New dict with modifier deltas applied.  Keys not affected by any modifier"
" are copied verbatim from base_stats."
msgstr ""
"Nouveau dict avec les deltas de modificateurs appliqués.  Les clés non "
"affectées par un modificateur sont copiées telles quelles depuis "
"base_stats."

#: axiom.modifiers.ModifierProcessor.add_modifier:12
#: axiom.modifiers.ModifierProcessor.apply_modifiers:17
#: axiom.modifiers.ModifierProcessor.snapshot_modifiers:15
#: axiom.modifiers.ModifierProcessor.tick_modifiers:17 of
msgid "On any database failure."
msgstr "Sur tout échec de base de données."

#: axiom.modifiers.ModifierProcessor.tick_modifiers:1 of
msgid "Decrement minutes_remaining for all modifiers of this save's entities."
msgstr ""
"Décrémente minutes_remaining pour tous les modificateurs des entités de "
"cette save."

#: axiom.modifiers.ModifierProcessor.tick_modifiers:3 of
msgid "For every active modifier associated with any entity in the database:"
msgstr "Pour chaque modificateur actif associé à une entité de la base :"

#: axiom.modifiers.ModifierProcessor.tick_modifiers:4 of
msgid "Decrements minutes_remaining by elapsed_minutes."
msgstr "Décrémente minutes_remaining d'elapsed_minutes."

#: axiom.modifiers.ModifierProcessor.tick_modifiers:5 of
msgid "Deletes the modifier if minutes_remaining reaches 0 after decrement."
msgstr "Supprime le modificateur si minutes_remaining atteint 0 après décrément."

#: axiom.modifiers.ModifierProcessor.tick_modifiers:7 of
msgid ""
"The save_id parameter scopes the tick to entities relevant to the given "
"save by joining through the State_Cache (entities that have cache entries"
" for this save).  If no scoping information exists, all entity modifiers "
"in Active_Modifiers are ticked."
msgstr ""
"Le paramètre save_id délimite le tick aux entités pertinentes pour la "
"save donnée en joignant le State_Cache (entités ayant des entrées de "
"cache pour cette save).  Sans information de délimitation, tous les "
"modificateurs d'entités d'Active_Modifiers sont tickés."

#: axiom.modifiers.ModifierProcessor.tick_modifiers:12 of
msgid "The save whose modifier timers are advanced."
msgstr "La save dont les minuteurs de modificateurs avancent."

#: axiom.modifiers.ModifierProcessor.tick_modifiers:13 of
msgid "Number of minutes that passed in-game."
msgstr "Nombre de minutes écoulées in-game."

#: axiom.modifiers.ModifierProcessor.tick_modifiers:15 of
msgid "List of modifier_id strings that were deleted (expired) this tick."
msgstr "Liste des modifier_id (chaînes) supprimés (expirés) à ce tick."

#: axiom.modifiers.ModifierProcessor.add_modifier:1 of
msgid "Insert a new modifier and return its generated modifier_id."
msgstr "Insère un nouveau modificateur et retourne son modifier_id généré."

#: axiom.modifiers.ModifierProcessor.add_modifier:3 of
msgid "The save this modifier is associated with."
msgstr "La save à laquelle ce modificateur est associé."

#: axiom.modifiers.ModifierProcessor.add_modifier:4 of
msgid "The entity the modifier affects."
msgstr "L'entité que le modificateur affecte."

#: axiom.modifiers.ModifierProcessor.add_modifier:5 of
msgid "The stat key the delta is applied to."
msgstr "La clé de stat à laquelle le delta s'applique."

#: axiom.modifiers.ModifierProcessor.add_modifier:6 of
msgid "Signed float adjustment (positive = buff, negative = debuff)."
msgstr "Ajustement float signé (positif = buff, négatif = debuff)."

#: axiom.modifiers.ModifierProcessor.add_modifier:7 of
msgid "Number of in-game minutes the modifier lasts (must be >= 1)."
msgstr "Nombre de minutes in-game que dure le modificateur (doit être >= 1)."

#: axiom.modifiers.ModifierProcessor.add_modifier:9 of
msgid "The newly generated modifier_id (UUID string)."
msgstr "Le modifier_id nouvellement généré (chaîne UUID)."

#: axiom.modifiers.ModifierProcessor.add_modifier:11 of
msgid "If minutes < 1."
msgstr "Si minutes < 1."

#: axiom.modifiers.ModifierProcessor.snapshot_modifiers:1 of
msgid "Capture this save's post-tick Active_Modifiers state for the turn."
msgstr ""

#: axiom.modifiers.ModifierProcessor.snapshot_modifiers:3 of
msgid ""
"Stores the buffs/debuffs (and their remaining minutes) so a later rewind "
"to this turn can restore them (TICKET-074). Active_Modifiers decays in "
"minutes and is hard-deleted on expiry, so it cannot be replayed from the "
"turn-keyed Event_Log — this snapshot is the faithful source."
msgstr ""

#: axiom.modifiers.ModifierProcessor.snapshot_modifiers:8 of
msgid ""
"No-op when the save has no active modifiers (the common case): the "
"absence of a row for a turn is what rewind reads as \"no modifiers "
"then\", so we never write empty rows. Call this once per turn, *after* "
"tick_modifiers."
msgstr ""

#: axiom.modifiers.ModifierProcessor.snapshot_modifiers:12 of
#, fuzzy
msgid "The save whose modifier state is captured."
msgstr "La save dont les minuteurs de modificateurs avancent."

#: axiom.modifiers.ModifierProcessor.snapshot_modifiers:13 of
msgid "The turn this state belongs to (end-of-turn, post-tick)."
msgstr ""

#: axiom.modifiers.rollback_modifiers:1 of
msgid "Restore a save's Active_Modifiers to its end-of-turn-N state on rewind."
msgstr ""

#: axiom.modifiers.rollback_modifiers:3 of
msgid ""
"Operates on the caller's open connection/transaction (like "
"``observations.rollback_observations``) so modifiers roll back atomically"
" with events, facts and beliefs. Two steps (TICKET-074):"
msgstr ""

#: axiom.modifiers.rollback_modifiers:7 of
msgid "Drop Modifier_Snapshots rows for turns after the target (future state)."
msgstr ""

#: axiom.modifiers.rollback_modifiers:8 of
msgid ""
"Replace the current Active_Modifiers for this save with the snapshot "
"captured at the target turn. If no snapshot exists for that turn — i.e. "
"the save had no active modifiers then (no row was written) — the save is "
"left with no modifiers, which is the correct empty state."
msgstr ""

#: axiom.modifiers.rollback_modifiers:13 of
msgid ""
"Note: a save loaded with modifiers but rewound to turn 0 (before any turn"
" was played/snapshotted) is cleared, consistent with rewind-to-0 wiping "
"the cache."
msgstr ""

#: ../../api/runtime.md:44
msgid "`axiom.multiplayer`"
msgstr ""

#: axiom.multiplayer:1 of
msgid "axiom.multiplayer — sequential turn-resolution queue."
msgstr "axiom.multiplayer — file de résolution séquentielle des tours."

#: axiom.multiplayer:3 of
msgid ""
"In multiplayer, player actions are resolved **one at a time** (FIFO) to "
"avoid any race on the database. Pure threading, zero Qt — the Qt shell "
"(`core/multiplayer_queue.py::ArbitratorWorker`) merely moves `run_loop` "
"onto a QThread and translates the callbacks into signals."
msgstr ""
"En multijoueur, les actions des joueurs sont résolues **une à la fois** "
"(FIFO) pour éviter toute course sur la base. Pur threading, zéro Qt — la "
"coquille Qt (`core/multiplayer_queue.py::ArbitratorWorker`) ne fait que "
"déporter `run_loop` sur un QThread et traduire les callbacks en signaux."

#: axiom.multiplayer.PlayerAction:1 of
msgid "A player action awaiting resolution."
msgstr "Une action de joueur en attente de résolution."

#: axiom.multiplayer.ActionQueue:1 of
msgid "FIFO queue of player actions, resolved sequentially by the arbitrator."
msgstr "File FIFO d'actions joueurs, résolues séquentiellement par l'arbitrator."

#: axiom.multiplayer.ActionQueue:3 of
msgid ""
"`run_loop` is blocking: the caller runs it on ITS thread (QThread on the "
"GUI side, plain Python thread headless). `enqueue` and `stop` are thread-"
"safe and callable from anywhere."
msgstr ""
"`run_loop` est bloquant : l'appelant le fait tourner sur SON thread "
"(QThread côté GUI, thread Python nu en headless). `enqueue` et `stop` "
"sont thread-safe et appelables de partout."

#: axiom.multiplayer.ActionQueue.enqueue:1 of
msgid "Add an action to resolve."
msgstr "Ajoute une action à résoudre."

#: axiom.multiplayer.ActionQueue.stop:1 of
msgid "Stop the loop cleanly (unblocks the pending `get`)."
msgstr "Arrête proprement la boucle (débloque le `get` en attente)."

#: axiom.multiplayer.ActionQueue.run_loop:1 of
msgid "Resolution loop: one action at a time, until `stop()`."
msgstr "Boucle de résolution : une action à la fois, jusqu'à `stop()`."

#: ../../api/runtime.md:51
msgid "`axiom.db_helpers`"
msgstr ""

#: axiom.db_helpers:1 of
msgid "workers/db_helpers.py"
msgstr ""

#: axiom.db_helpers:3 of
msgid "Synchronous database helper functions for one-time UI bootstrap reads."
msgstr ""
"Fonctions d'aide synchrones de base de données pour les lectures uniques "
"d'amorçage de l'UI."

#: axiom.db_helpers:5 of
msgid ""
"These are small, fast, lightweight operations that are acceptable to run "
"on the main thread during view construction or session initialisation "
"(e.g. reading 1–2 rows of metadata at session start)."
msgstr ""
"Ce sont de petites opérations rapides et légères, acceptables sur le "
"thread principal pendant la construction des vues ou l'initialisation de "
"session (ex. lire 1–2 lignes de métadonnées au démarrage)."

#: axiom.db_helpers:9 of
msgid ""
"All SQL strings in the project are concentrated in database/ and workers/"
" modules — never in ui/ files — to satisfy the MVC separation mandate."
msgstr ""
"Toutes les chaînes SQL du projet sont concentrées dans les modules "
"database/ et workers/ — jamais dans les fichiers ui/ — pour respecter la "
"séparation MVC."

#: axiom.db_helpers.apply_stat_preset:1 of
msgid "Apply a stat preset to a universe database."
msgstr "Applique un préréglage de stats à une base d'univers."

#: axiom.db_helpers.apply_stat_preset:3 axiom.db_helpers.create_new_save:3
#: axiom.db_helpers.get_current_time:3 axiom.db_helpers.get_max_turn_id:3
#: axiom.db_helpers.get_spatial_context:3
#: axiom.db_helpers.load_active_entities:7
#: axiom.db_helpers.load_rules_for_session:3 axiom.db_helpers.load_saves:6
#: axiom.db_helpers.read_universe_card_metadata:3 of
msgid "Path to the universe .db file."
msgstr "Chemin du fichier `.db` univers."

#: axiom.db_helpers.apply_stat_preset:4 of
msgid "Key in STAT_PRESETS."
msgstr "Clé dans STAT_PRESETS."

#: axiom.db_helpers.apply_stat_preset:6 of
msgid "Number of stats successfully added."
msgstr "Nombre de stats ajoutées avec succès."

#: axiom.db_helpers.read_universe_card_metadata:1 of
msgid "Read display metadata for a universe card widget."
msgstr "Lit les métadonnées d'affichage pour une carte d'univers."

#: axiom.db_helpers.read_universe_card_metadata:5 of
msgid ""
"Tuple of (universe_name, last_updated_str, difficulty_str). Returns "
"sensible defaults on any error."
msgstr ""
"Tuple (universe_name, last_updated_str, difficulty_str). Retourne des "
"défauts raisonnables en cas d'erreur."

#: axiom.db_helpers.provision_blank_universe:1 of
msgid "Insert default Universe_Meta rows into a freshly provisioned database."
msgstr ""
"Insère les lignes Universe_Meta par défaut dans une base fraîchement "
"provisionnée."

#: axiom.db_helpers.provision_blank_universe:3 of
msgid "Path to the universe .db file (already schema-provisioned)."
msgstr "Chemin du fichier `.db` univers (schéma déjà provisionné)."

#: axiom.db_helpers.provision_blank_universe:4 of
msgid "Human-readable universe name."
msgstr "Nom d'univers lisible par un humain."

#: axiom.db_helpers.create_new_save:1 of
msgid "Insert a new save row and return its save_id."
msgstr "Insère une nouvelle ligne de save et retourne son save_id."

#: axiom.db_helpers.create_new_save:4 of
msgid "Player's chosen name."
msgstr "Le nom choisi par le joueur."

#: axiom.db_helpers.create_new_save:5 of
msgid "\"Normal\" or \"Hardcore\"."
msgstr "\"Normal\" ou \"Hardcore\"."

#: axiom.db_helpers.create_new_save:6 of
msgid "Optional background / persona text for the player."
msgstr "Texte optionnel de background / persona du joueur."

#: axiom.db_helpers.create_new_save:8 of
msgid "The newly created UUID save_id string."
msgstr "La chaîne save_id (UUID) nouvellement créée."

#: axiom.db_helpers.load_saves:1 of
msgid "Read all saves for a universe, sorted most-recent first."
msgstr "Lit toutes les saves d'un univers, les plus récentes d'abord."

#: axiom.db_helpers.load_saves:3 of
msgid ""
"Runs the player_persona migration automatically so older databases remain"
" compatible."
msgstr ""
"Exécute automatiquement la migration player_persona pour que les "
"anciennes bases restent compatibles."

#: axiom.db_helpers.load_saves:8 of
msgid "save_id, player_name, difficulty, last_updated, player_persona."
msgstr "save_id, player_name, difficulty, last_updated, player_persona."

#: axiom.db_helpers.load_rules_for_session:1 of
msgid "Read all rules from a universe database for session initialisation."
msgstr ""
"Lit toutes les règles d'une base d'univers pour l'initialisation de "
"session."

#: axiom.db_helpers.load_rules_for_session:5 of
msgid ""
"List of rule dicts in canonical Rules Engine schema. Empty list if the "
"database cannot be read."
msgstr ""
"Liste de dicts de règles au schéma canonique du moteur de règles. Liste "
"vide si la base est illisible."

#: axiom.db_helpers.load_active_entities:1 of
msgid "Read all active entities (with their stats) for session initialisation."
msgstr ""
"Lit toutes les entités actives (avec leurs stats) pour l'initialisation "
"de session."

#: axiom.db_helpers.load_active_entities:3 of
msgid ""
"Mirrors the shape produced by `workers/db_worker.load_entities_and_rules`"
" (the list the GUI feeds to `NarrativeWorker`), so a headless `Session` "
"can resolve the Companion Hero entity itself instead of relying on the "
"UI."
msgstr ""
"Reproduit la forme produite par "
"`workers/db_worker.load_entities_and_rules` (la liste que le GUI fournit "
"au `NarrativeWorker`), pour qu'une `Session` headless puisse résoudre "
"elle-même l'entité Héros Compagnon au lieu de dépendre de l'UI."

#: axiom.db_helpers.load_active_entities:9 of
#, python-brace-format
msgid ""
"`{entity_id, entity_type, name, description, stats}`. Empty list if the "
"database cannot be read."
msgstr ""
"`{entity_id, entity_type, name, description, stats}`. Liste vide si la "
"base est illisible."

#: axiom.db_helpers.get_max_turn_id:1 of
msgid "Read the highest turn_id from Event_Log for a save (session resume)."
msgstr "Lit le turn_id maximal d'Event_Log pour une save (reprise de session)."

#: axiom.db_helpers.get_current_time:4 axiom.db_helpers.get_max_turn_id:4 of
