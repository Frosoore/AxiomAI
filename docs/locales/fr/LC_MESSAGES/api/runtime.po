#~ msgid "Force torch's native runtime to load on the *calling* (main) thread."
#~ msgstr ""
#~ "Force le runtime natif de torch à"
#~ " se charger sur le thread *appelant*"
#~ " (principal)."

#~ msgid ""
#~ "The sentence-transformers embedding model "
#~ "is loaded and used on worker "
#~ "threads (VectorInitWorker / NarrativeWorker). "
#~ "The first encode lazily pulls in "
#~ "``torch._dynamo`` → ``triton``, which "
#~ "``dlopen()``s ``libtriton.so``. Doing that "
#~ "``dlopen`` from a secondary thread while"
#~ " Qt is running segfaults (native "
#~ "crash, no Python traceback). Importing "
#~ "it once here, on the main thread"
#~ " at startup, makes the later "
#~ "cross-thread use safe."
#~ msgstr ""
#~ "Le modèle d'embedding sentence-transformers"
#~ " est chargé et utilisé sur des "
#~ "threads workers (VectorInitWorker / "
#~ "NarrativeWorker). Le premier encode tire "
#~ "paresseusement ``torch._dynamo`` → ``triton``, "
#~ "qui fait un ``dlopen()`` de "
#~ "``libtriton.so``. Faire ce ``dlopen`` depuis"
#~ " un thread secondaire pendant que Qt"
#~ " tourne segfaulte (plantage natif, sans "
#~ "traceback Python). L'importer une fois "
#~ "ici, sur le thread principal au "
#~ "démarrage, rend l'usage inter-threads "
#~ "ultérieur sûr."

#~ msgid ""
#~ "Call this from the GUI/CLI entry "
#~ "point *before* any worker thread touches"
#~ " VectorMemory. Idempotent, never raises. "
#~ "Returns True if the runtime was "
#~ "pre-loaded, False if torch is "
#~ "unavailable (e.g. headless test stubs)."
#~ msgstr ""
#~ "À appeler depuis le point d'entrée "
#~ "GUI/CLI *avant* qu'un thread worker ne"
#~ " touche à la VectorMemory. Idempotent, "
#~ "ne lève jamais. Retourne True si "
#~ "le runtime a été préchargé, False "
#~ "si torch est indisponible (ex. stubs "
#~ "de test headless)."

