msgstr "Le turn_id maximal, ou 0 si aucun événement n'existe."

#: axiom.db_helpers.get_current_time:1 of
msgid "Read the highest in_game_time from Timeline for a save."
msgstr "Lit le in_game_time maximal de la Timeline pour une save."

#: axiom.db_helpers.get_current_time:6 of
msgid "The maximum in_game_time in minutes, or 0 if no timeline exists."
msgstr "Le in_game_time maximal en minutes, ou 0 si aucune timeline n'existe."

#: axiom.db_helpers.get_time_of_day_context:1 of
